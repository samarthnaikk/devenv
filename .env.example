# Devenv uses OpenCode as the AI backend by default.
# OpenCode Zen credentials are stored locally (~/.local/share/opencode/auth.json).
# No .env variables are required — everything works out of the box.

# Optional overrides:
# OPENCODE_MODEL=opencode/claude-sonnet-4
# DEVENV_AVAILABLE_MODELS=opencode/claude-sonnet-4,opencode/deepseek-v4-flash-free
# DEVENV_OLLAMA_MODEL=qwen2.5:3b
# DEVENV_OLLAMA_BASE_URL=http://127.0.0.1:11434
# DEVENV_OLLAMA_NUM_CTX=4096
# DEVENV_OLLAMA_NUM_THREAD=4
# DEVENV_OLLAMA_KEEP_ALIVE=2m
